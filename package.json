{
  "name": "opencode-link",
  "version": "0.1.21",
  "type": "module",
  "description": "Messaging channel bridge for OpenCode — interact with your AI coding session from Discord, Slack, and more",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "opencode-link": "./dist/setup.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "setup:dev": "node scripts/setup-dev.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "discord",
    "slack",
    "messaging",
    "ai",
    "coding"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jin-chillo/opencode-link.git"
  },
  "homepage": "https://github.com/jin-chillo/opencode-link#readme",
  "bugs": {
    "url": "https://github.com/jin-chillo/opencode-link/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "discord.js": "^14.18.0",
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
